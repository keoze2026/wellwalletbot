{
  "name": "topup-bot",
  "version": "1.0.0",
  "description": "A Telegram bot built with TypeScript and grammY",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "typescript",
    "grammy"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
