# Telegram Bot token from @BotFather
BOT_TOKEN=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Admin Telegram user IDs (comma-separated) — only these can run /stop
ADMIN_IDS=

# Wallet API — used by the /topup command (the OAS only documents this dev server)
WALLET_API_BASE_URL=https://tag.dev.alfa-bot.com/api/dev/v1
# API key sent in the "token" header
WALLET_API_TOKEN=
