# Telegram Bot token from @BotFather
BOT_TOKEN=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Admin Telegram user IDs (comma-separated) — only these can run /stop
ADMIN_IDS=

# Wallet API — used by the /topup command
# prod: https://tag.alfa-bot.com/api/prod/v1   dev: https://tag.dev.alfa-bot.com/api/dev/v1
# Use whichever environment your server IP is allowlisted for.
WALLET_API_BASE_URL=https://tag.alfa-bot.com/api/prod/v1
# API key sent in the "token" header
WALLET_API_TOKEN=
# Wallet type for /topup deposits: "accounting" = exchange wallet, "user" = private wallet
WALLET_TYPE=accounting
